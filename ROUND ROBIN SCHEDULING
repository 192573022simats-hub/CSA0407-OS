#include<stdio.h>
int main()
{
    int bt[20],rt[20],n,tq,i,time=0,remain,wt=0,tat=0;
    printf("Enter number of processes: ");
    scanf("%d",&n);
    remain=n;
    for(i=0;i<n;i++)
    {
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }
    printf("Enter Time Quantum: ");
    scanf("%d",&tq);
    i=0;
    while(remain!=0)
    {
        if(rt[i]<=tq && rt[i]>0)
        {
            time+=rt[i];
            rt[i]=0;
            remain--;
            wt+=time-bt[i];
            tat+=time;
        }
        else if(rt[i]>0)
        {
            rt[i]-=tq;
            time+=tq;
        }
        if(i==n-1)
            i=0;
        else
            i++;
    }
    printf("Average Waiting Time = %.2f",(float)wt/n);
    printf("\nAverage Turnaround Time = %.2f",(float)tat/n);
    return 0;
}
